IDEA_BOUNTY_APP_NAME=idea-bounty-api
IDEA_BOUNTY_APP_ENV=development
IDEA_BOUNTY_DEBUG=false
IDEA_BOUNTY_DATABASE_URL=postgresql+psycopg://idea_bounty:idea_bounty_dev@localhost:5432/idea_bounty
IDEA_BOUNTY_TEST_DATABASE_URL=postgresql+psycopg://idea_bounty:idea_bounty_dev@localhost:5432/idea_bounty_test

# OpenAI Chat Completions 兼容生成模型
AI_BASE_URL=https://api.example.com/v1
AI_API_KEY=replace-with-your-api-key
AI_MODEL_ID=replace-with-your-model-id
AI_TIMEOUT_SECONDS=60
AI_MAX_RETRIES=2

# OpenAI Embeddings 兼容服务；生产列固定为 BAAI/bge-m3 的 1024 维规格
EMBEDDING_BASE_URL=https://api.example.com/v1
EMBEDDING_API_KEY=replace-with-your-api-key
EMBEDDING_MODEL_ID=BAAI/bge-m3
EMBEDDING_DIMENSIONS=1024
EMBEDDING_TIMEOUT_SECONDS=60
EMBEDDING_MAX_RETRIES=2
